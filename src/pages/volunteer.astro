---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get Involved | AI Collective Hampton Roads">
  <section class="page-header">
    <div class="container">
      <h1>Get Involved</h1>
      <p class="header-intro">Join our community and help shape the future of AI in Hampton Roads. Whether you want to volunteer, speak, sponsor, or collaborate — there's a place for you.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="opportunity-grid">
        <div class="card opportunity-card">
          <h3>Volunteer</h3>
          <p>Help organize events, mentor newcomers, or contribute to community projects. We welcome volunteers of all skill levels.</p>
          <ul>
            <li>Event planning and coordination</li>
            <li>Content creation and social media</li>
            <li>Technical mentorship</li>
            <li>Community outreach</li>
          </ul>
          <a href="https://docs.google.com/forms/d/e/1FAIpQLScOjiPZTlrEtYPa23AyvYLa8XvfWQHXhFC3QUde-5FdFkmlcQ/viewform?usp=header" target="_blank" rel="noopener" class="btn btn-primary">Get Involved</a>
        </div>

        <div class="card opportunity-card">
          <h3>Speak at Events</h3>
          <p>Share your knowledge and experience with the community through talks, workshops, or panel discussions.</p>
          <ul>
            <li>Technical presentations</li>
            <li>Workshop facilitation</li>
            <li>Panel discussions</li>
            <li>Lightning talks</li>
          </ul>
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSeSEQNaZ_FK-9b6xtDRysL15ishcfQJnbU5pse7rrg4wZVBpQ/viewform?usp=header" target="_blank" rel="noopener" class="btn btn-primary">Propose a Talk</a>
        </div>

        <div class="card opportunity-card">
          <h3>Sponsor / Partner</h3>
          <p>Support our mission by sponsoring events, providing venues, or contributing resources to help our community grow.</p>
          <ul>
            <li>Event sponsorship</li>
            <li>Venue hosting</li>
            <li>Equipment and resources</li>
            <li>Student scholarships</li>
          </ul>
          <a href="/partnerships" class="btn btn-primary">View Partnership Tiers</a>
        </div>

        <div class="card opportunity-card">
          <h3>Join the Community</h3>
          <p>Connect with AI enthusiasts, researchers, and professionals in the Hampton Roads area through our online communities.</p>
          <ul>
            <li>Attend meetups and events</li>
            <li>Join our Facebook group</li>
            <li>Collaborate on projects</li>
            <li>Network with peers</li>
          </ul>
          <a href="https://www.facebook.com/groups/claudecodeforbusiness" target="_blank" rel="noopener" class="btn btn-primary">Join Facebook Group</a>
        </div>

        <div class="card opportunity-card featured-card">
          <h3>1-on-1 Mentorship</h3>
          <p>Book a personal session with Ted Patterson at Assembly for hands-on guidance in business, tech, UI/UX, or AI. In-person mentorship tailored to where you are right now.</p>
          <ul>
            <li>Business strategy & planning</li>
            <li>Technology implementation</li>
            <li>UI/UX design guidance</li>
            <li>AI tools & workflows</li>
          </ul>
          <a href="https://sites.google.com/view/757-1on1-assistance/" target="_blank" rel="noopener" class="btn btn-primary">Book a 1-on-1 Session</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">Questions?</h2>
      <p class="closing-text">Reach out to us at <a href="mailto:andrewstafford@aicollective.com" class="email-link">andrewstafford@aicollective.com</a> or <a href="mailto:ted@aicollective.com" class="email-link">ted@aicollective.com</a></p>
      <div style="margin-top: var(--spacing-lg);">
        <a href="/connect#booking" class="btn btn-primary">Book a Discovery Call</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-primary);
    padding: var(--spacing-xl) 0;
  }

  .page-header h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: var(--spacing-sm);
  }

  .header-intro {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    max-width: 700px;
    line-height: 1.7;
  }

  .opportunity-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  .opportunity-card {
    display: flex;
    flex-direction: column;
  }

  .opportunity-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-sm);
    color: var(--color-primary);
  }

  .opportunity-card p {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-md);
  }

  .opportunity-card ul {
    list-style: none;
    margin-bottom: var(--spacing-lg);
    flex-grow: 1;
    padding: 0;
  }

  .opportunity-card li {
    padding: 0.375rem 0;
    color: var(--color-text);
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.95rem;
  }

  .opportunity-card li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }

  .closing-text {
    font-size: 1.15rem;
    color: var(--color-text);
  }

  .email-link {
    color: var(--color-primary);
    font-weight: 600;
  }

  .email-link:hover {
    text-decoration: underline;
  }

  .featured-card {
    border-color: var(--color-secondary);
    background: linear-gradient(135deg, var(--color-bg-alt), rgba(42, 123, 155, 0.05));
  }

  .featured-card h3 {
    color: var(--color-secondary);
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .opportunity-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
