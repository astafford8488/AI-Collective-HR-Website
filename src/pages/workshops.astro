---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Workshops & Trainings | AI Collective Hampton Roads">
  <section class="page-header">
    <div class="container">
      <h1>One-Off Workshops & Trainings</h1>
      <p class="header-intro">Standalone engagements delivered at your location, customized to your industry, tools, and goals. Our facilitators bring 25+ years of technology leadership, with experience at Amazon, NASA, and multiple startup exits. With 49+ seminars delivered and over 1,000 attendees, we know how to make AI actionable for your team.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-header">
            <span class="tier-label">Tier 1</span>
            <h3>Lunch & Learn | Keynote</h3>
            <div class="price">$2,500 – $3,000</div>
          </div>
          <div class="pricing-body">
            <div class="pricing-meta">
              <div class="meta-item"><strong>Duration:</strong> 1 – 1.5 hours</div>
              <div class="meta-item"><strong>Attendees:</strong> Up to 50</div>
              <div class="meta-item"><strong>Best for:</strong> Leadership teams, all-hands, departments wanting a high-level AI overview</div>
            </div>
            <h4>Included:</h4>
            <ul>
              <li>Pre-event discovery/scoping call</li>
              <li>Custom slide deck</li>
              <li>Post-event resource packet (tools list, guides, next steps)</li>
            </ul>
            <h4>Available Add-Ons:</h4>
            <p class="addons-text">Recorded video, summary report, 30-day Q&A</p>
          </div>
        </div>

        <div class="pricing-card featured">
          <div class="pricing-header">
            <span class="tier-label">Tier 2</span>
            <h3>Half-Day Workshop</h3>
            <div class="price">$5,500 – $7,500</div>
          </div>
          <div class="pricing-body">
            <div class="pricing-meta">
              <div class="meta-item"><strong>Duration:</strong> 2 – 4 hours</div>
              <div class="meta-item"><strong>Attendees:</strong> Up to 30</div>
              <div class="meta-item"><strong>Best for:</strong> Teams ready to get hands-on with AI tools and workflows</div>
            </div>
            <h4>Included:</h4>
            <ul>
              <li>Everything in Lunch & Learn, PLUS:</li>
              <li>Custom hands-on exercises and live demos</li>
              <li>Follow-up summary report to leadership</li>
            </ul>
            <h4>Available Add-Ons:</h4>
            <p class="addons-text">Recorded video, 30-day Q&A support</p>
          </div>
        </div>

        <div class="pricing-card">
          <div class="pricing-header">
            <span class="tier-label">Tier 3</span>
            <h3>Full-Day Bootcamp</h3>
            <div class="price">$12,000 – $15,000</div>
          </div>
          <div class="pricing-body">
            <div class="pricing-meta">
              <div class="meta-item"><strong>Duration:</strong> 6 – 8 hours</div>
              <div class="meta-item"><strong>Attendees:</strong> Up to 30 (dual facilitators)</div>
              <div class="meta-item"><strong>Best for:</strong> Organizations seeking a comprehensive AI transformation day</div>
            </div>
            <h4>Included:</h4>
            <ul>
              <li>Everything in Half-Day, PLUS:</li>
              <li>Dual facilitators</li>
              <li>Extended hands-on labs</li>
              <li>Recorded session video</li>
              <li>30-day post-event Q&A support</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">A La Carte Add-Ons</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Add-On</th>
              <th>Price</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Recorded session video</td>
              <td>$500 – $750</td>
            </tr>
            <tr>
              <td>Follow-up summary report to leadership</td>
              <td>$600 – $1,000</td>
            </tr>
            <tr>
              <td>30-day post-event Q&A support (email/Slack)</td>
              <td>$1,200 – $1,500</td>
            </tr>
            <tr>
              <td>Additional facilitator</td>
              <td>$1,500 – $2,500</td>
            </tr>
            <tr>
              <td>Attendees beyond cap (+10 people)</td>
              <td>$750 – $1,000</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container" style="text-align: center;">
      <p class="closing-text">Multi-session series and custom formats available. Contact us to discuss your needs.</p>
      <a href="/connect#booking" class="btn btn-primary">Book a Discovery Call</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-primary);
    padding: var(--spacing-xl) 0;
  }

  .page-header h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: var(--spacing-sm);
  }

  .header-intro {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    max-width: 780px;
    line-height: 1.7;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    align-items: start;
  }

  .pricing-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.2s;
  }

  .pricing-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .pricing-card.featured {
    border: 2px solid var(--color-primary);
    position: relative;
  }

  .pricing-card.featured .pricing-header {
    background: linear-gradient(135deg, #D4742C, #E8943A);
  }

  .pricing-card.featured .pricing-header h3,
  .pricing-card.featured .pricing-header .price,
  .pricing-card.featured .pricing-header .tier-label {
    color: var(--color-white);
  }

  .pricing-header {
    padding: var(--spacing-lg);
    background: var(--color-bg-alt);
    text-align: center;
  }

  .tier-label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-secondary);
    margin-bottom: var(--spacing-xs);
  }

  .pricing-header h3 {
    font-size: 1.35rem;
    margin-bottom: var(--spacing-sm);
  }

  .price {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-primary);
  }

  .pricing-body {
    padding: var(--spacing-lg);
  }

  .pricing-meta {
    margin-bottom: var(--spacing-md);
  }

  .meta-item {
    font-size: 0.95rem;
    margin-bottom: var(--spacing-xs);
    color: var(--color-text);
  }

  .pricing-body h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-top: var(--spacing-md);
    margin-bottom: var(--spacing-xs);
  }

  .pricing-body ul {
    list-style: none;
    padding: 0;
  }

  .pricing-body ul li {
    padding: 0.375rem 0;
    font-size: 0.95rem;
    color: var(--color-text);
    padding-left: 1.25rem;
    position: relative;
  }

  .pricing-body ul li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .addons-text {
    font-size: 0.9rem;
    color: var(--color-text-light);
    font-style: italic;
  }

  .table-wrapper {
    overflow-x: auto;
    max-width: 700px;
  }

  .closing-text {
    font-size: 1.15rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-lg);
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }
</style>
