---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Events | AI Collective Hampton Roads">
  <section class="page-header">
    <div class="container">
      <h1>AI Education Built for the Real World</h1>
      <p class="header-intro">Our events are designed for professionals who need practical, applicable AI knowledge — not academic theory. Every session is built so attendees leave with tools, frameworks, and workflows they can put to use immediately.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">By The Numbers</h2>
      <div class="stats-grid">
        <div class="stat-block">
          <span class="stat-number">49</span>
          <span class="stat-label">Events delivered in 2025</span>
        </div>
        <div class="stat-block">
          <span class="stat-number">70+</span>
          <span class="stat-label">Events planned for 2026</span>
        </div>
        <div class="stat-block">
          <span class="stat-number">1,000+</span>
          <span class="stat-label">Total attendees to date</span>
        </div>
        <div class="stat-block">
          <span class="stat-number">210K+</span>
          <span class="stat-label">Global AI Collective community</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">What We Cover</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Topic Area</th>
              <th>Examples</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>AI Strategy & Adoption</strong></td>
              <td>Readiness assessments, AI-first culture, responsible AI governance</td>
            </tr>
            <tr>
              <td><strong>Hands-On AI Tools</strong></td>
              <td>Prompt engineering, content & marketing workflows, copilot deep-dives</td>
            </tr>
            <tr>
              <td><strong>Automation & No-Code</strong></td>
              <td>Business process automation, no-code MVPs, workflow optimization</td>
            </tr>
            <tr>
              <td><strong>Technical Deep-Dives</strong></td>
              <td>ML fundamentals, AI in healthcare & regulated industries, AI security</td>
            </tr>
            <tr>
              <td><strong>Career & Workforce</strong></td>
              <td>AI-proofing careers, upskilling teams, AI-augmented roles</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Event Formats</h2>
      <div class="formats-grid">
        <div class="card">
          <h3>Keynotes</h3>
          <p>All-hands meetings, leadership offsites, conference stages</p>
        </div>
        <div class="card">
          <h3>Workshops</h3>
          <p>Hands-on guided sessions with real-time tool building</p>
        </div>
        <div class="card">
          <h3>Bootcamps</h3>
          <p>Full-day immersive training with dual facilitators</p>
        </div>
        <div class="card">
          <h3>Demo Nights</h3>
          <p>Live showcases of AI tools, products, and projects</p>
        </div>
        <div class="card">
          <h3>Panel Discussions</h3>
          <p>Curated conversations with practitioners and leaders</p>
        </div>
        <div class="card">
          <h3>Networking</h3>
          <p>Structured and open networking for AI-interested professionals</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Where We've Delivered</h2>
      <div class="venues-row">
        <span class="venue-tag">Norfolk State University</span>
        <span class="venue-tag">Old Dominion University</span>
        <span class="venue-tag">ECPI University</span>
        <span class="venue-tag">Assembly</span>
        <span class="venue-tag">The Hive</span>
        <span class="venue-tag">ISSA Hampton Roads</span>
        <span class="venue-tag">Local Businesses</span>
        <span class="venue-tag">Online Venues</span>
      </div>
    </div>
  </section>

  <section class="section upcoming-events">
    <div class="container">
      <h2 class="section-title">Upcoming Events</h2>
      <p class="section-subtitle">Register for our next event on Luma</p>
      <div class="luma-embed-wrapper">
        <iframe
          src="https://lu.ma/embed/calendar/cal-aicollectivehr/events"
          style="border: 0; width: 100%; height: 600px; border-radius: 12px;"
          allowfullscreen
        ></iframe>
      </div>
      <p class="alt-links">
        Also find us on
        <a href="https://www.meetup.com/aicollectivehr/" target="_blank" rel="noopener">Meetup</a> ·
        <a href="https://luma.com/user/aicollectivehr" target="_blank" rel="noopener">Luma</a> ·
        <a href="https://linktr.ee/aicollectivehr" target="_blank" rel="noopener">Linktree</a>
      </p>
    </div>
  </section>

  <section class="section event-resources">
    <div class="container">
      <h2 class="section-title">Event Resources</h2>
      <p class="section-subtitle">Materials, guides, and links for our events</p>

      <div class="event-accordion">
        <details class="event-item" open>
          <summary class="event-toggle">
            <span class="event-date">April 9, 2026</span>
            <span class="event-name">Claude Code: From Setup to Agentic Workflows</span>
            <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="event-details">
            <div class="resource-grid">
              <a href="https://docs.google.com/document/d/1YdVF4q84xwY6IWD5-amk9ytSMNAKRUVp_pheW2JQuMw/edit?usp=sharing" target="_blank" rel="noopener" class="resource-card">
                <span class="resource-icon">📋</span>
                <span class="resource-label">Homework Guide</span>
                <span class="resource-desc">Pre-event setup checklist & QR code</span>
              </a>
              <a href="https://docs.google.com/document/d/1K_5Jk3ostqag_hbYUaLdK37riYFgnf4eUFiSh4w4LOY/edit?tab=t.0" target="_blank" rel="noopener" class="resource-card">
                <span class="resource-icon">🛠️</span>
                <span class="resource-label">Demo Setup Guide</span>
                <span class="resource-desc">Step-by-step environment setup</span>
              </a>
              <a href="https://gamma.app/docs/Claude-Code-From-Setup-to-Agentic-Workflows-4sr9a4vgh0d2wcs?mode=doc" target="_blank" rel="noopener" class="resource-card">
                <span class="resource-icon">📊</span>
                <span class="resource-label">Presentation Slides</span>
                <span class="resource-desc">Full slide deck from the session</span>
              </a>
              <a href="https://andrewverse2054.gumroad.com/l/xcwoub" target="_blank" rel="noopener" class="resource-card">
                <span class="resource-icon">🚀</span>
                <span class="resource-label">DFY Starter Kit</span>
                <span class="resource-desc">Done-for-you Claude Code starter pack</span>
              </a>
            </div>
          </div>
        </details>

        <!-- More events will be added here as they happen -->
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">Bring an Event to Your Organization</h2>
      <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">We customize every engagement for your team, your industry, and your goals.</p>
      <a href="/workshops" class="btn btn-primary">View Workshop Packages</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-primary);
    padding: var(--spacing-xl) 0;
  }

  .page-header h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: var(--spacing-sm);
  }

  .header-intro {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    max-width: 720px;
    line-height: 1.7;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-lg);
    text-align: center;
  }

  .stat-block {
    padding: var(--spacing-lg);
    background: var(--color-bg-alt);
    border-radius: 8px;
  }

  .stat-number {
    display: block;
    font-size: 2.75rem;
    font-weight: 900;
    color: var(--color-secondary);
    line-height: 1.1;
    margin-bottom: var(--spacing-xs);
  }

  .stat-label {
    font-size: 0.95rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .formats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .venues-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .venue-tag {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 0.625rem 1.25rem;
    border-radius: 100px;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .upcoming-events {
    background: var(--color-bg-alt);
  }

  .luma-embed-wrapper {
    margin-bottom: var(--spacing-lg);
  }

  .alt-links {
    font-size: 0.95rem;
    color: var(--color-text-light);
  }

  .alt-links a {
    color: var(--color-primary);
    font-weight: 500;
  }

  .event-resources {
    background: var(--color-white);
  }

  .event-accordion {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .event-item {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .event-toggle {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md) var(--spacing-lg);
    cursor: pointer;
    font-weight: 500;
    color: var(--color-text);
    list-style: none;
    transition: background 0.2s;
  }

  .event-toggle::-webkit-details-marker {
    display: none;
  }

  .event-toggle:hover {
    background: var(--color-border);
  }

  .event-date {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-secondary);
    background: rgba(42, 123, 155, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .event-name {
    flex: 1;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .chevron {
    transition: transform 0.2s;
    flex-shrink: 0;
    color: var(--color-text-light);
  }

  details[open] .chevron {
    transform: rotate(180deg);
  }

  .event-details {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--spacing-sm);
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-md);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .resource-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .resource-icon {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-xs);
  }

  .resource-label {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }

  .resource-desc {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .cta-section {
    background: var(--color-white);
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .formats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
