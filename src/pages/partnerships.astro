---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Partnership Programs | AI Collective Hampton Roads">
  <section class="page-header">
    <div class="container">
      <h1>Partner With Us</h1>
      <p class="header-intro">Embed ongoing AI education into your organization through a structured partnership. Our tiered programs provide consistent access to workshops, events, speaking engagements, and brand visibility within Hampton Roads' AI community.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">What We Need From Partners</h2>
      <p class="section-subtitle">Partnerships aren't just financial. We value resources, expertise, and community access.</p>
      <div class="needs-grid">
        <div class="card need-card">
          <div class="need-icon"><Icon name="calendar" size={28} /></div>
          <h3>Event Logistics & Hospitality</h3>
          <p>Food & beverage sponsorship, signage, photo backdrops, name badges, chapter swag</p>
        </div>
        <div class="card need-card">
          <div class="need-icon"><Icon name="megaphone" size={28} /></div>
          <h3>Visibility & Community Growth</h3>
          <p>Speaker referrals, workshop facilitation, photography, social media amplification, event spaces</p>
        </div>
        <div class="card need-card">
          <div class="need-icon"><Icon name="code" size={28} /></div>
          <h3>Tech Tools & Career Development</h3>
          <p>Tech resource donations, job & internship leads, resume nights, subscriptions or grants</p>
        </div>
        <div class="card need-card">
          <div class="need-icon"><Icon name="wallet" size={28} /></div>
          <h3>Financial Support & Infrastructure</h3>
          <p>Monetary contributions, paid speaker fees, storage & logistics, professional services, grant support</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Partnership Tiers</h2>
      <p class="section-subtitle">Tiers are based on funds or resources per month. Large contributions ($250+) not earmarked for a specific meetup may be spread across months.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Tier</th>
              <th>Monthly</th>
              <th>Quarterly</th>
              <th>Annual</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Silver</strong></td>
              <td>$250</td>
              <td>$750</td>
              <td>$3,000</td>
            </tr>
            <tr>
              <td><strong>Gold</strong></td>
              <td>$500</td>
              <td>$1,500</td>
              <td>$5,750</td>
            </tr>
            <tr class="tier-highlight">
              <td><strong>Platinum</strong></td>
              <td>$1,000</td>
              <td>$2,750</td>
              <td>$11,000</td>
            </tr>
            <tr class="tier-highlight">
              <td><strong>Diamond</strong></td>
              <td>$3,000</td>
              <td>$8,500</td>
              <td>$35,000</td>
            </tr>
            <tr class="tier-premium">
              <td><strong>Global</strong></td>
              <td>$4,000+</td>
              <td>$11,000+</td>
              <td>$45,000+</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">What Each Tier Includes</h2>
      <p class="section-subtitle">Benefits scale with tier level. Higher tiers include all benefits from lower tiers.</p>

      <div class="tier-details">
        <details class="tier-accordion">
          <summary class="tier-toggle">
            <span class="tier-badge silver">Silver</span>
            <span class="tier-summary">Social media recognition & celebration posts</span>
            <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="tier-content">
            <ul>
              <li>Celebration posts on LinkedIn, Instagram, and Facebook</li>
              <li>Social media mentions and tags</li>
              <li>All Quartz and Bronze benefits included</li>
            </ul>
          </div>
        </details>

        <details class="tier-accordion">
          <summary class="tier-toggle">
            <span class="tier-badge gold">Gold</span>
            <span class="tier-summary">In-event exposure, speaking slot & branding</span>
            <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="tier-content">
            <ul>
              <li>Host recognition and partner slides at events</li>
              <li>Emcee call-outs during events</li>
              <li>Optional 1-minute speaking slot</li>
              <li>Branding on event materials</li>
              <li>Instagram & TikTok coverage</li>
              <li>Everything in Silver</li>
            </ul>
          </div>
        </details>

        <details class="tier-accordion" open>
          <summary class="tier-toggle">
            <span class="tier-badge platinum">Platinum</span>
            <span class="tier-summary">Branded workshops, strategy syncs & email call-outs</span>
            <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="tier-content">
            <ul>
              <li>Private 30-minute strategy sync with chapter leads</li>
              <li>Branded workshops: 10–30 attendees, up to 1.5 hours</li>
              <li>1 keynote, fireside chat, or workshop featured segment</li>
              <li>Top logo placement on event materials</li>
              <li>Dedicated highlight posts across all platforms</li>
              <li>Pre- and post-event email call-outs (mention)</li>
              <li>Speaking opportunity (1 min+)</li>
              <li>Everything in Gold</li>
            </ul>
          </div>
        </details>

        <details class="tier-accordion">
          <summary class="tier-toggle">
            <span class="tier-badge diamond">Diamond</span>
            <span class="tier-summary">Co-branded events, Demo Nights & full guest list access</span>
            <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="tier-content">
            <ul>
              <li>Co-branding across all event materials, website, and emails</li>
              <li>Larger branded events: 30–60 attendees, up to 2.5 hours</li>
              <li>Full multi-platform social media coverage</li>
              <li>Pre- and post-event email blurbs and follow-up inclusion</li>
              <li>Full guest list access after events</li>
              <li><strong>Demo Night (AI Innovation Live):</strong> Up to 75 attendees, 1.5 hours, branding on all materials</li>
              <li>Integrated event access for up to 3 team members</li>
              <li>Everything in Platinum</li>
            </ul>
          </div>
        </details>

        <details class="tier-accordion">
          <summary class="tier-toggle">
            <span class="tier-badge global">Global</span>
            <span class="tier-summary">Reach beyond Hampton Roads into global AI Collective channels</span>
            <svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="tier-content">
            <ul>
              <li>Visibility beyond Hampton Roads into global AI Collective channels</li>
              <li>Elevated logo placement at international scale</li>
              <li>Enriched access to guest lists, partners, and global activations</li>
              <li>Everything in Diamond</li>
            </ul>
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container" style="text-align: center;">
      <h2 class="section-title">Become a Partner</h2>
      <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">Ready to embed AI education into your organization? Let's find the right tier for your goals.</p>
      <a href={`${base}/connect#booking`} class="btn btn-primary">Book a Discovery Call</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-primary);
    padding: var(--spacing-xl) 0;
  }

  .page-header h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: var(--spacing-sm);
  }

  .header-intro {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    max-width: 780px;
    line-height: 1.7;
  }

  .needs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  .need-card {
    text-align: center;
  }

  .need-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    background: rgba(42, 123, 155, 0.1);
    color: var(--color-secondary);
    border-radius: 8px;
    margin: 0 auto var(--spacing-sm);
  }

  .need-card h3 {
    font-size: 1.1rem;
    margin-bottom: var(--spacing-xs);
  }

  .need-card p {
    font-size: 0.95rem;
    color: var(--color-text-light);
  }

  .table-wrapper {
    overflow-x: auto;
  }

  table {
    width: 100%;
    max-width: 700px;
  }

  .tier-highlight td {
    background: var(--color-bg-alt);
    font-weight: 500;
  }

  .tier-premium td {
    background: rgba(212, 116, 44, 0.08);
    font-weight: 600;
  }

  .tier-details {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .tier-accordion {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-white);
  }

  .tier-toggle {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md) var(--spacing-lg);
    cursor: pointer;
    font-weight: 500;
    color: var(--color-text);
    list-style: none;
    transition: background 0.2s;
  }

  .tier-toggle::-webkit-details-marker {
    display: none;
  }

  .tier-toggle:hover {
    background: var(--color-bg-alt);
  }

  .tier-badge {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    white-space: nowrap;
    color: var(--color-white);
  }

  .tier-badge.silver { background: #8E8E8E; }
  .tier-badge.gold { background: #C9952B; }
  .tier-badge.platinum { background: #5B7B8A; }
  .tier-badge.diamond { background: var(--color-secondary); }
  .tier-badge.global { background: var(--color-primary); }

  .tier-summary {
    flex: 1;
    font-size: 0.95rem;
    color: var(--color-text-light);
  }

  .chevron {
    transition: transform 0.2s;
    flex-shrink: 0;
    color: var(--color-text-light);
  }

  details[open] .chevron {
    transform: rotate(180deg);
  }

  .tier-content {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
  }

  .tier-content ul {
    list-style: none;
    padding: 0;
  }

  .tier-content li {
    padding: 0.5rem 0;
    font-size: 0.95rem;
    color: var(--color-text);
    padding-left: 1.5rem;
    position: relative;
    border-bottom: 1px solid var(--color-bg-alt);
  }

  .tier-content li:last-child {
    border-bottom: none;
  }

  .tier-content li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .needs-grid {
      grid-template-columns: 1fr;
    }

    .tier-toggle {
      flex-wrap: wrap;
      gap: var(--spacing-xs);
    }

    .tier-summary {
      width: 100%;
    }
  }
</style>
