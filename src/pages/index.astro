---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="AI Collective Hampton Roads | A Local Chapter of the Global AI Community"
  description="A community chapter making AI education accessible across Hampton Roads — free public events, hands-on workshops, and a welcoming space for anyone curious about AI. Part of the 210,000-member global AI Collective."
>
  <section class="hero" style={`background-image: url('${base}/photos/AICbanner1.jpg');`}>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <span class="hero-eyebrow">AI Collective · Hampton Roads Chapter</span>
      <h1 class="display">Making AI accessible — <em>one neighbor</em> at a time.</h1>
      <p class="hero-subtitle">We're the Hampton Roads chapter of The AI Collective — a community of neighbors, practitioners, students, and educators exploring what AI means for our work, our careers, and our region. Most of what we do is free and open to everyone.</p>
      <div class="hero-actions">
        <a href={`${base}/events`} class="btn btn-primary">See Upcoming Events</a>
        <a href={`${base}/volunteer`} class="btn btn-hero-secondary">Get Involved</a>
      </div>
      <div class="hero-chips">
        <span class="chip">Community-Rated 4.7★</span>
        <span class="chip">1,000+ Neighbors Welcomed</span>
        <span class="chip">49 Events in 2025</span>
        <span class="chip">Part of a 210K+ Global Community</span>
      </div>
    </div>
  </section>

  <section class="venues-band">
    <div class="container">
      <p class="venues-label">Gathering across Hampton Roads at</p>
      <div class="venues-row">
        <span class="venue-name">Old Dominion University</span>
        <span class="venue-dot">·</span>
        <span class="venue-name">Norfolk State University</span>
        <span class="venue-dot">·</span>
        <span class="venue-name">ECPI University</span>
        <span class="venue-dot">·</span>
        <span class="venue-name">Assembly</span>
        <span class="venue-dot">·</span>
        <span class="venue-name">The Hive</span>
        <span class="venue-dot">·</span>
        <span class="venue-name">ISSA Hampton Roads</span>
      </div>
    </div>
  </section>

  <section class="stats section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-number">49</span>
          <span class="stat-label">Events Delivered in 2025</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">1,000+</span>
          <span class="stat-label">Total Attendees</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">210K+</span>
          <span class="stat-label">Global AI Community</span>
        </div>
      </div>
    </div>
  </section>

  <section class="gallery-section">
    <div class="container">
      <span class="section-number">In the Rooms</span>
      <h2 class="section-title">Real events. <em>Real people.</em> Real work.</h2>
      <p class="section-subtitle">A snapshot of 2025: workshops at Norfolk State, keynotes at Assembly, Vibecoding cohorts, and dozens of sessions across the 757.</p>
    </div>
    <div class="gallery-strip">
      <div class="gallery-row">
        <img src={`${base}/photos/PXL_20250819_222743676.MP.jpg`} alt="AI workshop in session — attendees working at laptops" loading="lazy" />
        <img src={`${base}/photos/PXL_20251218_234010977.jpg`} alt="Andrew Stafford delivering a keynote" loading="lazy" />
        <img src={`${base}/photos/PXL_20251016_232333449.MP.jpg`} alt="Group photo at the AI Collective Hampton Roads" loading="lazy" />
        <img src={`${base}/photos/IMG_2535.jpg`} alt="AIC team and attendees at a workshop" loading="lazy" />
        <img src={`${base}/photos/PXL_20251114_010447787.jpg`} alt="Vibecoding 101 cohort celebration" loading="lazy" />
        <img src={`${base}/photos/1773430366623.jpeg`} alt="Veterans Forge event group photo" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="what-we-do section section-alt">
    <div class="container">
      <span class="section-number">01 — What We Do</span>
      <h2 class="section-title">A chapter built around <em>three kinds of gatherings.</em></h2>
      <p class="section-subtitle">Most of our work is free public programming. When teams ask us to bring a session to their organization privately, we're glad to — and the fees help fund everything else we do for the community.</p>
      <div class="services-grid">
        <a href={`${base}/events`} class="card service-card">
          <div class="service-icon"><Icon name="users" size={28} /></div>
          <h3>Free Community Events</h3>
          <p>Monthly meetups, demo nights, and hands-on workshops open to anyone in the 757 — no cost, no prerequisites, just curiosity.</p>
          <span class="card-link">See upcoming &rarr;</span>
        </a>
        <a href={`${base}/workshops`} class="card service-card">
          <div class="service-icon"><Icon name="graduation-cap" size={28} /></div>
          <h3>Private Team Sessions</h3>
          <p>Sometimes organizations want us to bring a workshop or keynote in-house. We do — and those fees fund the free community programming.</p>
          <span class="card-link">How it works &rarr;</span>
        </a>
        <a href={`${base}/partnerships`} class="card service-card">
          <div class="service-icon"><Icon name="handshake" size={28} /></div>
          <h3>Partners & Supporters</h3>
          <p>Local businesses, universities, and civic partners who host, sponsor, or collaborate with the chapter. Every partner helps us reach more people.</p>
          <span class="card-link">Join as a partner &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="differentiator band-teal section">
    <div class="container">
      <span class="eyebrow" style="color: rgba(255,255,255,0.9);">Our Mission</span>
      <h2 class="display differentiator-headline">AI shouldn't be <em>something that happens to you.</em></h2>
      <p class="differentiator-body">We started this chapter because we believe everyone in Hampton Roads — from students and career changers to small-business owners and civic leaders — deserves a place to learn about AI from people who've actually used it in the real world. No gatekeeping, no jargon, no pressure to buy anything. Show up, ask questions, meet your neighbors.</p>
      <a href={`${base}/about`} class="differentiator-link">Read more about the chapter &rarr;</a>
    </div>
  </section>

  <section class="testimonials section">
    <div class="container">
      <div class="testimonials-header">
        <div>
          <span class="section-number">02 — From Attendees</span>
          <h2 class="section-title">What people say after they <em>join us.</em></h2>
          <p class="section-subtitle">Notes from neighbors who've come to our 2025 events. Everyone's welcome — whether it's your first AI meetup or your fiftieth.</p>
        </div>
        <div class="rating-badge">
          <div class="rating-score">4.7</div>
          <div class="rating-stars">★★★★★</div>
          <div class="rating-count">129 ratings</div>
        </div>
      </div>

      <div class="testimonial-grid">
        <blockquote class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-quote">"Great insight into Claude, integrations and the orchestration and the tasks that you can set up. Awesome."</p>
          <footer class="testimonial-meta">
            <div class="testimonial-author">Kiran</div>
            <div class="testimonial-event">Claude Code: From Setup to Agentic Workflows</div>
          </footer>
        </blockquote>

        <blockquote class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-quote">"Great event! I would definitely attend more of these events!"</p>
          <footer class="testimonial-meta">
            <div class="testimonial-author">Eric B. Jones</div>
            <div class="testimonial-event">Black BRAND × AIC: Website Creation Meetup</div>
          </footer>
        </blockquote>

        <blockquote class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-quote">"I loved the class. I got up and running with Mobbin and Bolt — would love even more time to explore the tools."</p>
          <footer class="testimonial-meta">
            <div class="testimonial-author">Terri Hargrave-Bradley</div>
            <div class="testimonial-event">Vibecoding 101: Launch Your Idea Today</div>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="final-cta section section-alt">
    <div class="container" style="text-align: center;">
      <span class="section-number" style="display: inline-block;">03 — Get Involved</span>
      <h2 class="section-title" style="margin-left: auto; margin-right: auto; max-width: 720px;">There's a way in <em>for everyone.</em></h2>
      <p class="section-subtitle" style="margin-left: auto; margin-right: auto;">Come to a meetup. Volunteer with the chapter. Speak at an event. Host us at your space. Or just follow along. Whatever fits your time and interest.</p>
      <div class="cta-row">
        <a href={`${base}/events`} class="btn btn-primary">Upcoming Events</a>
        <a href={`${base}/volunteer`} class="btn btn-secondary">Ways to Get Involved</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    background-size: cover;
    background-position: center;
    min-height: 600px;
    display: flex;
    align-items: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(212, 116, 44, 0.88), rgba(42, 123, 155, 0.82));
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: var(--spacing-2xl) 0;
    max-width: 820px;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 1.25rem;
    padding: 0.375rem 0.875rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 100px;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: var(--spacing-md);
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .hero h1 em {
    font-style: italic;
    color: #FFE4C4;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: var(--spacing-xl);
    line-height: 1.65;
    max-width: 680px;
  }

  .hero-actions {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-xl);
  }

  .btn-hero-secondary {
    display: inline-block;
    padding: 0.875rem 2rem;
    border-radius: 6px;
    font-weight: 500;
    font-size: 1rem;
    background: transparent;
    color: var(--color-white);
    border: 2px solid var(--color-white);
    transition: all 0.2s;
    text-align: center;
  }

  .btn-hero-secondary:hover {
    background: var(--color-white);
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .chip {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.375rem 0.875rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(4px);
  }

  /* VENUES BAND */
  .venues-band {
    background: #F7F1EA;
    border-bottom: 1px solid var(--color-border);
    padding: 1.75rem 0;
  }

  .venues-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-light);
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .venues-row {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
  }

  .venue-name {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }

  .venue-dot {
    color: var(--color-border);
    font-weight: 700;
  }

  /* STATS */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    text-align: center;
  }

  .stat-card {
    padding: var(--spacing-lg);
  }

  .stat-number {
    display: block;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.25rem;
    font-weight: 900;
    color: var(--color-secondary);
    line-height: 1.1;
    margin-bottom: var(--spacing-xs);
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 1rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  /* WHAT WE DO */
  .section-title em {
    font-style: italic;
    color: var(--color-secondary);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    margin-top: var(--spacing-xl);
  }

  .service-card {
    text-decoration: none;
    display: block;
  }

  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    background: rgba(212, 116, 44, 0.08);
    color: var(--color-primary);
    border-radius: 8px;
    margin-bottom: var(--spacing-sm);
  }

  .service-card h3 {
    margin-bottom: var(--spacing-sm);
  }

  .service-card p {
    margin-bottom: var(--spacing-md);
  }

  .card-link {
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.95rem;
  }

  /* DIFFERENTIATOR BAND */
  .differentiator {
    position: relative;
    overflow: hidden;
  }

  .differentiator::before {
    content: '';
    position: absolute;
    top: -80px;
    right: -80px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .differentiator-headline {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    color: var(--color-white);
    max-width: 820px;
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.015em;
  }

  .differentiator-headline em {
    font-style: italic;
    color: #FFE4C4;
  }

  .differentiator-body {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 720px;
    line-height: 1.8;
    margin-bottom: var(--spacing-md);
  }

  .differentiator-link {
    display: inline-block;
    color: var(--color-white);
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }

  .differentiator-link:hover {
    color: var(--color-white);
    border-bottom-color: var(--color-white);
  }

  /* FINAL CTA */
  .final-cta {
    padding: var(--spacing-2xl) 0;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 520px;
    }

    .hero h1 {
      font-size: 2.1rem;
    }

    .hero-subtitle {
      font-size: 1.05rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-sm);
    }

    .stat-card {
      padding: var(--spacing-sm);
    }

    .stat-number {
      font-size: 2.5rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .venues-row {
      gap: 0.5rem 0.75rem;
    }

    .venue-name {
      font-size: 0.85rem;
    }

    .gallery-row {
      grid-auto-columns: 72vw !important;
    }

    .testimonials-header {
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .testimonial-grid {
      grid-template-columns: 1fr !important;
    }

    .cta-row {
      flex-direction: column;
      align-items: center;
    }
  }

  /* GALLERY STRIP */
  .gallery-section {
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
    background: var(--color-white);
    overflow: hidden;
  }

  .gallery-strip {
    margin-top: var(--spacing-lg);
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: thin;
    padding: 0 var(--spacing-md) var(--spacing-sm);
    -webkit-overflow-scrolling: touch;
  }

  .gallery-row {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(320px, 1fr);
    gap: var(--spacing-md);
    padding: 0 calc((100vw - 1200px) / 2);
  }

  .gallery-row img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: var(--shadow-md);
    transition: transform 0.3s ease;
  }

  .gallery-row img:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  /* TESTIMONIALS */
  .testimonials {
    background: var(--color-white);
  }

  .testimonials-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
    flex-wrap: wrap;
  }

  .testimonials-header > div:first-child {
    flex: 1;
    min-width: 320px;
  }

  .rating-badge {
    text-align: center;
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    min-width: 180px;
  }

  .rating-score {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3rem;
    font-weight: 900;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .rating-stars {
    color: #E8943A;
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    margin-bottom: 0.25rem;
  }

  .rating-count {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }

  .testimonial-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--spacing-lg);
    margin: 0;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .testimonial-stars {
    color: #E8943A;
    font-size: 0.95rem;
    letter-spacing: 0.15em;
    margin-bottom: var(--spacing-sm);
  }

  .testimonial-quote {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem;
    font-style: italic;
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
    flex-grow: 1;
  }

  .testimonial-meta {
    border-top: 1px solid var(--color-border);
    padding-top: var(--spacing-sm);
  }

  .testimonial-author {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .testimonial-event {
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-top: 0.25rem;
  }

  /* CTA ROW */
  .cta-row {
    display: inline-flex;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-sm);
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
