---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="AI Collective Hampton Roads | AI Education & Workforce Development">
  <section class="hero" style={`background-image: url('${base}/AICHR.png');`}>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1>AI Education & Workforce Development for Hampton Roads</h1>
      <p class="hero-subtitle">Practitioner-led workshops, trainings, and keynotes that give your team AI skills they can use Monday morning.</p>
      <div class="hero-actions">
        <a href={`${base}/workshops`} class="btn btn-primary">Explore Our Workshops</a>
        <a href={`${base}/connect#booking`} class="btn btn-hero-secondary">Book a Discovery Call</a>
      </div>
    </div>
  </section>

  <section class="stats section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-number">49</span>
          <span class="stat-label">Events Delivered in 2025</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">1,000+</span>
          <span class="stat-label">Total Attendees</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">210K+</span>
          <span class="stat-label">Global AI Community</span>
        </div>
      </div>
    </div>
  </section>

  <section class="what-we-do section section-alt">
    <div class="container">
      <h2 class="section-title">What We Do</h2>
      <div class="services-grid">
        <a href={`${base}/workshops`} class="card service-card">
          <h3>Workshops & Trainings</h3>
          <p>Hands-on sessions customized to your industry, tools, and goals. From lunch & learns to full-day bootcamps.</p>
          <span class="card-link">Learn more &rarr;</span>
        </a>
        <a href={`${base}/events`} class="card service-card">
          <h3>Keynotes & Speaking</h3>
          <p>High-impact presentations for leadership offsites, all-hands meetings, and conference stages.</p>
          <span class="card-link">Learn more &rarr;</span>
        </a>
        <a href={`${base}/partnerships`} class="card service-card">
          <h3>Partnerships</h3>
          <p>Ongoing AI education programs embedded in your organization's growth strategy.</p>
          <span class="card-link">Learn more &rarr;</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    background-size: cover;
    background-position: center;
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(212, 116, 44, 0.85), rgba(42, 123, 155, 0.75));
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: var(--spacing-2xl) 0;
    max-width: 760px;
  }

  .hero h1 {
    font-size: 2.75rem;
    font-weight: 900;
    color: var(--color-white);
    margin-bottom: var(--spacing-md);
    line-height: 1.15;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--spacing-xl);
    line-height: 1.7;
    max-width: 640px;
  }

  .hero-actions {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .btn-hero-secondary {
    display: inline-block;
    padding: 0.875rem 2rem;
    border-radius: 6px;
    font-weight: 500;
    font-size: 1rem;
    background: transparent;
    color: var(--color-white);
    border: 2px solid var(--color-white);
    transition: all 0.2s;
    text-align: center;
  }

  .btn-hero-secondary:hover {
    background: var(--color-white);
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    text-align: center;
  }

  .stat-card {
    padding: var(--spacing-lg);
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 900;
    color: var(--color-secondary);
    line-height: 1.1;
    margin-bottom: var(--spacing-xs);
  }

  .stat-label {
    font-size: 1rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .service-card {
    text-decoration: none;
    display: block;
  }

  .service-card h3 {
    margin-bottom: var(--spacing-sm);
  }

  .service-card p {
    margin-bottom: var(--spacing-md);
  }

  .card-link {
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1.05rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-sm);
    }

    .stat-card {
      padding: var(--spacing-sm);
    }

    .stat-number {
      font-size: 2.25rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
