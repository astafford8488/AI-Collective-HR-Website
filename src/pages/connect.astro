---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Connect | AI Collective Hampton Roads">
  <section class="page-header">
    <div class="container">
      <h1>Let's Connect</h1>
      <p class="header-intro">Whether you're ready to book a workshop, explore a partnership, or just want to learn more about what we do — we'd love to hear from you.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="connect-grid">
        <div class="contact-info">
          <h2 class="section-title">Get in Touch</h2>
          <div class="contact-cards">
            <div class="contact-card">
              <h3>Andrew Stafford</h3>
              <a href="mailto:andrewstafford@aicollective.com">andrewstafford@aicollective.com</a>
            </div>
            <div class="contact-card">
              <h3>Ted Patterson</h3>
              <a href="mailto:ted@aicollective.com">ted@aicollective.com</a>
              <a href="https://www.linkedin.com/in/tedjpatterson/" target="_blank" rel="noopener">LinkedIn Profile &rarr;</a>
            </div>
            <div class="contact-card">
              <h3>Organization</h3>
              <a href="https://www.linkedin.com/company/aicollectivehr/" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: middle; margin-right: 0.375rem;"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn Page
              </a>
              <a href="https://www.facebook.com/groups/claudecodeforbusiness" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: middle; margin-right: 0.375rem;"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Claude Code for Business (Facebook Group)
              </a>
              <a href="https://linktr.ee/aicollectivehr" target="_blank" rel="noopener">Linktree &rarr;</a>
            </div>
          </div>
        </div>

        <div class="form-section" id="booking">
          <h2 class="section-title">Book a Discovery Call</h2>
          <p class="booking-intro">Schedule a free discovery call to discuss your team's needs, explore workshop options, or learn about partnership opportunities.</p>
          <div class="booking-embed">
            <iframe
              src="https://api.leadconnectorhq.com/widget/booking/UlmCnAh2HarbC1PskHgW"
              style="border: 0; width: 100%; height: 700px; border-radius: 8px;"
              scrolling="no"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-primary);
    padding: var(--spacing-xl) 0;
  }

  .page-header h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: var(--spacing-sm);
  }

  .header-intro {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    max-width: 640px;
    line-height: 1.7;
  }

  .connect-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--spacing-2xl);
    align-items: start;
  }

  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .contact-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--spacing-md);
  }

  .contact-card h3 {
    font-size: 1.1rem;
    margin-bottom: var(--spacing-xs);
  }

  .contact-card a {
    display: block;
    font-size: 0.95rem;
    color: var(--color-primary);
    margin-top: 0.25rem;
  }

  .contact-card a:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  .booking-intro {
    font-size: 1rem;
    color: var(--color-text-light);
    margin-bottom: var(--spacing-lg);
    line-height: 1.6;
  }

  .booking-embed {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .connect-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
    }
  }
</style>
