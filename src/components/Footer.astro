<style>
  footer {
    background: #1A1A2E;
    color: var(--color-white);
    padding: var(--spacing-xl) 0 var(--spacing-lg);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--spacing-xl);
  }

  .footer-logo {
    height: 50px;
    width: auto;
    margin-bottom: var(--spacing-sm);
  }

  .footer-brand p {
    font-size: 0.9rem;
    opacity: 0.9;
    margin-bottom: var(--spacing-xs);
  }

  .footer-parent a {
    color: var(--color-white);
    text-decoration: underline;
  }

  .footer-parent a:hover {
    color: var(--color-white);
    opacity: 0.8;
  }

  h4 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
    color: var(--color-white);
  }

  ul {
    list-style: none;
  }

  ul li {
    margin-bottom: var(--spacing-xs);
  }

  ul li a {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: opacity 0.2s;
  }

  ul li a:hover {
    color: var(--color-white);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
      text-align: center;
    }

    ul li a {
      justify-content: center;
    }
  }
</style>
